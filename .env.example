# WhatsApp Cloud API (Meta for Developers > your app > WhatsApp > API Setup)
NUXT_WHATSAPP_ACCESS_TOKEN=
NUXT_WHATSAPP_PHONE_NUMBER_ID=
# App secret (Meta app > Settings > Basic) — used to verify webhook signatures
NUXT_WHATSAPP_APP_SECRET=
# Meta app ID (Meta app > Settings > Basic) — used by start-bot.command to
# keep the webhook callback URL in sync with the dev tunnel
META_APP_ID=
# Any random string; must match the verify token you enter in the webhook config
NUXT_WHATSAPP_VERIFY_TOKEN=

# Google AI Studio key (https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# Neon Postgres connection string
DATABASE_URL=
